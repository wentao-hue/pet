@@ -1154,6 +1154,24 @@
 	bool
 	depends on !STACK_GROWSUP
 
+config PET_TIERING
+	bool "PET proactive demotion prototype"
+	depends on X86_64 && MMU && NUMA && NUMA_BALANCING && MIGRATION
+	help
+	  Enable a prototype implementation of PET (Proactive Demotion for
+	  Efficient Tiered Memory Management).  PET captures anonymous mmap()
+	  allocation ranges as P-blocks, samples PTE accessed bits, uses
+	  PROT_NONE canary faults for PHASE2/DEMOTED P-blocks, proactively
+	  demotes cold P-blocks and cold file pages, and promotes re-accessed
+	  demoted P-blocks with a background kpromoted thread.
+
+	  PET reuses the NUMA-balancing PROT_NONE PTE encoding for its canary
+	  pages, so NUMA_BALANCING must be built in; disable it at runtime
+	  (kernel.numa_balancing=0) while PET experiments run.
+
+	  This is an experimental reconstruction of the EuroSys 2025 PET paper,
+	  intended for research reproduction rather than production use.
+
 source "mm/damon/Kconfig"
 
 endmenu
